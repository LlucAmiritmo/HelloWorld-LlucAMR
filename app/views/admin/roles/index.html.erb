<h1>Roles</h1>

<p>
  <%= link_to "New role", new_admin_role_path %>
</p>

<table>
  <thead>
    <tr>
      <th>Code</th>
      <th>Description</th>
      <th>Admin</th>
      <th>User</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @roles.each do |role| %>
      <tr>
        <td><%= role.code %></td>
        <td><%= role.description %></td>
        <td><%= role.admin %></td>
        <td><%= role.user %></td>
        <td>
          <%= link_to "Show", admin_role_path(role) %>
          <%= link_to "Edit", edit_admin_role_path(role) %>
          <%= button_to "Delete", admin_role_path(role), method: :delete, data: { turbo_confirm: "Are you sure?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>