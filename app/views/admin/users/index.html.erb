<h1>Users</h1>

<p>
  <%= link_to "New user", new_admin_user_path %>
</p>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Login</th>
      <th>Role</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td><%= user.login %></td>
        <td><%= user.role&.code %></td>
        <td>
          <%= link_to "Show", admin_user_path(user) %>
          <%= link_to "Edit", edit_admin_user_path(user) %>
          <%= button_to "Delete", admin_user_path(user), method: :delete, data: { turbo_confirm: "Are you sure?" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>