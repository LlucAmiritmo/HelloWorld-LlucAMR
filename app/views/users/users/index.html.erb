<h1>Users</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Login</th>
      <th>Role</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td><%= user.login %></td>
        <td><%= user.role.code %></td>
        <td>
          <%= link_to "Show", users_user_path(user) %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>