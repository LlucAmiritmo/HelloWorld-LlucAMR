<h1>Roles</h1>

<table>
  <thead>
    <tr>
      <th>Code</th>
      <th>Description</th>
      <th>Admin</th>
      <th>User</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% @roles.each do |role| %>
      <tr>
        <td><%= role.code %></td>
        <td><%= role.description %></td>
        <td><%= role.admin %></td>
        <td><%= role.user %></td>
        <td>
          <%= link_to "Show", users_role_path(role) %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>